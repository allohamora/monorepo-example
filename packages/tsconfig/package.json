{
  "name": "@example/tsconfig",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier . --check",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@example/prettier-config": "*",
    "@types/node": "^24.12.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "prettier": "@example/prettier-config",
  "lint-staged": {
    "*.{js,cjs,mjs,json,yml,md}": "prettier --write"
  },
  "engines": {
    "node": ">=v24.13.0",
    "npm": ">=11.11.0"
  },
  "packageManager": "npm@11.11.0"
}
