{
  "name": "@example/root",
  "version": "0.0.1",
  "description": "a monorepo example",
  "author": "https://github.com/allohamora",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "generate:package": "plop package",
    "release": "node scripts/release.ts",
    "format": "prettier . --check",
    "format:fix": "prettier --write .",
    "lint": "eslint \"**/*.ts\"",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@example/eslint-config": "*",
    "@example/prettier-config": "*",
    "@example/tsconfig": "*",
    "@types/node": "^24.12.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "plop": "^4.0.5",
    "prettier": "^3.8.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "zx": "^8.8.5"
  },
  "prettier": "@example/prettier-config",
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=v24.13.0",
    "npm": ">=11.6.2"
  },
  "packageManager": "npm@11.6.2",
  "lint-staged": {
    "*.{js,cjs,mjs,json,yml,md}": "prettier --write",
    "*.ts": "eslint --fix"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allohamora/monorepo-example.git"
  },
  "bugs": {
    "url": "https://github.com/allohamora/monorepo-example/issues"
  },
  "homepage": "https://github.com/allohamora/monorepo-example#readme"
}
